# Copy to .env (gitignored), then fill in the blanks.
# Loaded into the devcontainer via docker-compose env_file and referenced by .vscode/launch.json.

# HTTP port the MCP server listens on (streamable HTTP endpoint served at /mcp)
PORT=8080

# Gmail account used to send mail (SMTP smtp.gmail.com:587 STARTTLS).
# Must equal the From / authenticated account.
GMAIL_USERNAME=michael@blacktoaster.com

# Gmail APP PASSWORD (16-char app-specific password, NOT your account password).
GMAIL_APP_PASSWORD=

# Bearer token required on requests to /mcp. Generate a strong random value, e.g.:
#   openssl rand -hex 32
BEARER_TOKEN=

# Fixed recipient for every notification (the tool exposes no recipient parameter).
NOTIFY_RECIPIENT=michael@blacktoaster.com
